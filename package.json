{
  "name": "vecta-atama",
  "productName": "Vecta Atama",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "npm run build && electron .",
    "electron": "electron .",
    "dist": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "lucide-react": "^1.17.0",
    "mediainfo.js": "^0.3.7",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.vecta.atama",
    "productName": "Vecta Atama",
    "files": ["electron/**", "dist/**"],
    "directories": { "output": "release" },
    "win": { "target": "portable" }
